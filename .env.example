NODE_ENV=development
PORT=3000

# Database
DATABASE_PATH=./data/speedmaster.db

# Sessions (replace with 32+ random bytes in production)
SESSION_SECRET=replace-me-with-32-random-bytes

# Orders API — HMAC shared secret between frontend and CMS
# Frontend signs POST /api/orders body with this secret
ORDERS_API_SECRET=replace-me-with-orders-secret

# SMTP — use Mailpit locally (smtp://localhost:1025) for testing
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SpeedMaster <ops@speedmaster.bike>"
OPS_CC=ops@speedmaster.bike

# Branding (used in email templates)
BRAND_NAME=SpeedMaster
BRAND_DOMAIN=www.speedmaster.bike
