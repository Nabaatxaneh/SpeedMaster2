<%- include('_header', { navActive: 'variants' }) %>

<% if (locals.flash) { %>
<div class="alert alert--<%= flash.type %>" data-autodismiss><%= flash.message %></div>
<% } %>

<div class="toolbar">
  <form method="get" action="/admin/variants" style="display:contents">
    <input class="field__input" style="max-width:240px" type="search" name="q" value="<%= query.q||'' %>" placeholder="Search SKU, colour, name…">
    <button type="submit" class="btn btn--secondary btn--sm">Search</button>
  </form>
</div>

<form action="/admin/variants/bulk/action" method="post">
<div class="bulk-bar" id="bulk-bar">
  <span><span id="bulk-count">0</span> selected</span>
  <select class="field__select" name="bulk_action" style="width:auto;font-size:.8rem">
    <option value="set_stock">Set Stock Status</option>
  </select>
  <select class="field__select" name="bulk_stock" style="width:auto;font-size:.8rem">
    <option value="Available">Available</option>
    <option value="Out of Stock">Out of Stock</option>
    <option value="Pre-sale">Pre-sale</option>
  </select>
  <button type="submit" class="btn btn--primary btn--sm" data-confirm="Apply to selected variants?">Apply</button>
</div>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th><input type="checkbox" id="select-all"></th>
        <th>SKU</th><th>Product</th><th>Colour</th>
        <th>Wholesale</th><th>RRP</th><th>Retail</th><th>Stock</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% if (variants.length === 0) { %>
      <tr><td colspan="9" style="text-align:center;padding:2rem;" class="text-muted">No variants found.</td></tr>
      <% } %>
      <% variants.forEach(v => { %>
      <tr>
        <td><input type="checkbox" name="variant_ids[]" value="<%= v.id %>" class="row-check"></td>
        <td class="text-xs"><%= v.sku %></td>
        <td class="text-sm"><a href="/admin/products/<%= v.product_id %>"><%= v.brand||'' %> <%= v.model_name %></a></td>
        <td><%= v.color||'—' %></td>
        <td><%= formatGBP(v.wholesale_cost_pence) %></td>
        <td><%= formatGBP(v.rrp_pence) %></td>
        <td><%= formatGBP(v.retail_price_pence) %></td>
        <td><span class="badge <%= v.stock_status==='Available'?'badge--green':v.stock_status==='Pre-sale'?'badge--orange':'badge--red' %>"><%= v.stock_status %></span></td>
        <td>
          <button type="button" class="btn btn--ghost btn--sm" onclick="document.getElementById('edit-modal-<%= v.id %>').showModal()">Edit</button>
          <dialog id="edit-modal-<%= v.id %>" style="padding:1.5rem;border-radius:.75rem;border:1px solid #E5E4DF;min-width:360px;">
            <form action="/admin/variants/<%= v.id %>" method="post">
              <h3 style="margin-bottom:1rem;">Edit Variant: <%= v.sku %></h3>
              <div style="display:flex;flex-direction:column;gap:.75rem;">
                <div class="field"><label class="field__label">SKU</label><input class="field__input" name="sku" value="<%= v.sku %>" required></div>
                <div class="field"><label class="field__label">Colour</label><input class="field__input" name="color" value="<%= v.color||'' %>"></div>
                <div class="field"><label class="field__label">Wholesale Cost (£)</label><input class="field__input" type="number" step="0.01" name="wholesale_cost" value="<%= (v.wholesale_cost_pence/100).toFixed(2) %>"></div>
                <div class="field"><label class="field__label">RRP (£)</label><input class="field__input" type="number" step="0.01" name="rrp" value="<%= (v.rrp_pence/100).toFixed(2) %>"></div>
                <div class="field"><label class="field__label">Retail Price (£)</label><input class="field__input" type="number" step="0.01" name="retail_price" value="<%= (v.retail_price_pence/100).toFixed(2) %>"></div>
                <div class="field"><label class="field__label">Stock</label>
                  <select class="field__select" name="stock_status">
                    <option <%=v.stock_status==='Available'?'selected':''%>>Available</option>
                    <option <%=v.stock_status==='Out of Stock'?'selected':''%>>Out of Stock</option>
                    <option <%=v.stock_status==='Pre-sale'?'selected':''%>>Pre-sale</option>
                  </select>
                </div>
                <div style="display:flex;gap:.5rem;">
                  <button type="submit" class="btn btn--primary btn--sm">Save</button>
                  <button type="button" class="btn btn--ghost btn--sm" onclick="this.closest('dialog').close()">Cancel</button>
                </div>
              </div>
            </form>
          </dialog>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
</form>

<% const totalPages = Math.ceil(total / perPage); %>
<% if (totalPages > 1) { %>
<div class="pagination">
  <% for (let p = 1; p <= totalPages; p++) { %>
    <% if (p === currentPage) { %><span class="current"><%= p %></span>
    <% } else { %><a href="?<%= new URLSearchParams({...query, page: p}).toString() %>"><%= p %></a><% } %>
  <% } %>
</div>
<% } %>

<%- include('_footer') %>
