<%- include('_header', { navActive: 'reconciliation' }) %>

<% if (locals.flash) { %>
<div class="alert alert--<%= flash.type %>" data-autodismiss><%= flash.message %></div>
<% } %>

<form method="get" action="/admin/reconciliation">
<div class="filter-row">
  <div class="field">
    <label class="field__label">Supplier</label>
    <select class="field__select" name="supplier_id">
      <option value="">All suppliers</option>
      <% suppliers.forEach(s => { %><option value="<%= s.id %>" <%=query.supplier_id==s.id?'selected':''%>><%= s.name %></option><% }) %>
    </select>
  </div>
  <div class="field">
    <label class="field__label">Shipped From</label>
    <input class="field__input" type="date" name="from" value="<%= query.from||'' %>">
  </div>
  <div class="field">
    <label class="field__label">To</label>
    <input class="field__input" type="date" name="to" value="<%= query.to||'' %>">
  </div>
  <div class="field" style="justify-content:flex-end;flex-direction:row;align-items:flex-end;gap:.5rem;">
    <button type="submit" class="btn btn--secondary">Filter</button>
    <a href="/admin/reconciliation/export?<%= new URLSearchParams(query).toString() %>" class="btn btn--ghost btn--sm">Export CSV</a>
  </div>
</div>
</form>

<form action="/admin/reconciliation/settle" method="post" id="settle-form">
  <div class="bulk-bar" id="bulk-bar">
    <span><span id="bulk-count">0</span> selected</span>
    <button type="submit" class="btn btn--primary btn--sm" data-confirm="Mark selected orders as Settled and stamp settled_at now?">Mark Selected as Settled</button>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th><input type="checkbox" id="select-all" aria-label="Select all"></th>
          <th>Reference</th><th>Shipped</th><th>Customer</th>
          <th>SKU</th><th>Retail Paid</th><th>Supplier Cost</th><th>Supplier</th>
        </tr>
      </thead>
      <tbody>
        <% if (orders.length === 0) { %>
        <tr><td colspan="8" style="text-align:center;padding:2rem;" class="text-muted">No pending settled orders found.</td></tr>
        <% } %>
        <% orders.forEach(o => { %>
        <tr>
          <td><input type="checkbox" name="order_ids[]" value="<%= o.order_id %>" class="row-check"></td>
          <td><a href="/admin/orders/<%= o.order_id %>"><%= o.order_reference %></a></td>
          <td class="text-xs text-muted"><%= o.shipped_at ? new Date(o.shipped_at).toLocaleDateString('en-GB') : '—' %></td>
          <td><%= o.customer_name %></td>
          <td class="text-xs"><%= o.sku %></td>
          <td><%= formatGBP(o.retail_price_paid_pence) %></td>
          <td><strong><%= formatGBP(o.supplier_cost_basis_pence) %></strong></td>
          <td><%= o.supplier_name||'—' %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr class="table-total">
          <td colspan="6" style="text-align:right;padding:.75rem 1rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;font-size:.75rem;">Total Supplier Cost</td>
          <td style="padding:.75rem 1rem;font-size:1.1rem;"><strong><%= formatGBP(subtotal) %></strong></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>
</form>

<% const totalPages = Math.ceil(total / perPage); %>
<% if (totalPages > 1) { %>
<div class="pagination">
  <% for (let p = 1; p <= totalPages; p++) { %>
    <% if (p === currentPage) { %><span class="current"><%= p %></span>
    <% } else { %><a href="?<%= new URLSearchParams({...query, page: p}).toString() %>"><%= p %></a><% } %>
  <% } %>
</div>
<% } %>

<%- include('_footer') %>
