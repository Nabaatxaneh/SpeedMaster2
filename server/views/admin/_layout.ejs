<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — SpeedMaster Admin</title>
  <meta name="robots" content="noindex,nofollow">
  <link rel="stylesheet" href="/admin/static/admin.css">
</head>
<body>
<div class="admin-layout">

  <!-- ── Sidebar ──────────────────────────────────────────────────────── -->
  <aside class="admin-sidebar">
    <a class="sidebar__logo" href="/admin/dashboard">
      <img src="/brand_assets/logo.png" alt="SpeedMaster">
    </a>
    <% if (typeof process !== 'undefined' && process.env.NODE_ENV !== 'production') { %>
    <span class="sidebar__env">Dev</span>
    <% } %>

    <nav class="sidebar__nav">
      <div class="sidebar__section-label">Operations</div>
      <a href="/admin/dashboard"       class="<%= title==='Dashboard'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/admin/orders"          class="<%= title==='Orders'||title.startsWith('Order')?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Orders
      </a>
      <a href="/admin/reconciliation"  class="<%= title==='Reconciliation'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/><circle cx="12" cy="12" r="10"/></svg>
        Reconciliation
      </a>

      <div class="sidebar__section-label">Catalogue</div>
      <a href="/admin/products"   class="<%= title==='Products'||title.startsWith('Edit')||title==='New Product'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-4 0v2M8 7V5a2 2 0 00-4 0v2"/></svg>
        Products
      </a>
      <a href="/admin/variants"   class="<%= title==='Variants'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        Variants
      </a>
      <a href="/admin/pages"      class="<%= title==='CMS Pages'||title.startsWith('Edit:')|| title==='New Page'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Pages
      </a>
      <a href="/admin/media"      class="<%= title==='Media Library'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        Media
      </a>

      <div class="sidebar__section-label">Admin</div>
      <a href="/admin/suppliers"  class="<%= title==='Suppliers'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Suppliers
      </a>
      <a href="/admin/imports"    class="<%= title==='Imports'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0018 9h-1.26A8 8 0 103 16.29"/></svg>
        Imports
      </a>
      <a href="/admin/users"      class="<%= title==='Admin Users'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Users
      </a>
      <a href="/admin/settings"   class="<%= title==='Settings'?'active':'' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        Settings
      </a>
      <a href="/admin/audit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Audit Log
      </a>
    </nav>

    <div class="sidebar__footer">
      <div class="sidebar__user">
        <strong><%= user?.name || 'Unknown' %></strong>
        <%= user?.email %>
      </div>
      <form action="/admin/logout" method="post">
        <button type="submit" class="btn btn--ghost btn--sm" style="width:100%;justify-content:center;color:#fff;border-color:rgba(255,255,255,.2)">Sign Out</button>
      </form>
    </div>
  </aside>

  <!-- ── Main ─────────────────────────────────────────────────────────── -->
  <main class="admin-main">
    <header class="admin-topbar">
      <button id="mobile-menu-btn" class="btn btn--ghost btn--sm" style="display:none" aria-label="Menu">☰</button>
      <h1 class="admin-topbar__title"><%= title %></h1>
    </header>

    <div class="admin-content">
      <%- body %>
    </div>
  </main>
</div>

<script src="/admin/static/admin.js"></script>
</body>
</html>
