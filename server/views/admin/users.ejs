<%- include('_header', { navActive: 'users' }) %>

<% if (locals.flash) { %>
<div class="alert alert--<%= flash.type %>" data-autodismiss><%= flash.message %></div>
<% } %>

<div class="toolbar">
  <a href="/admin/users/new" class="btn btn--primary btn--sm" style="margin-left:auto">+ New User</a>
</div>

<div class="table-wrap">
  <table>
    <thead>
      <tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Created</th><th></th></tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
      <tr>
        <td><strong><%= u.name %></strong></td>
        <td class="text-sm"><%= u.email %></td>
        <td><span class="badge <%= u.role==='admin'?'badge--yellow':'badge--gray' %>"><%= u.role %></span></td>
        <td>
          <% if (u.locked_until && new Date(u.locked_until) > new Date()) { %>
          <span class="badge badge--red">Locked until <%= new Date(u.locked_until).toLocaleTimeString('en-GB') %></span>
          <% } else if (u.failed_attempts > 0) { %>
          <span class="badge badge--orange"><%= u.failed_attempts %> failed attempts</span>
          <% } else { %>
          <span class="badge badge--green">OK</span>
          <% } %>
        </td>
        <td class="text-xs text-muted"><%= new Date(u.created_at).toLocaleDateString('en-GB') %></td>
        <td><a href="/admin/users/<%= u.id %>" class="btn btn--ghost btn--sm">Edit</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('_footer') %>
