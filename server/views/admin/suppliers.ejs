<%- include('_header', { navActive: 'suppliers' }) %>

<% if (locals.flash) { %>
<div class="alert alert--<%= flash.type %>" data-autodismiss><%= flash.message %></div>
<% } %>

<div class="toolbar">
  <a href="/admin/suppliers/new" class="btn btn--primary btn--sm" style="margin-left:auto">+ New Supplier</a>
</div>

<div class="table-wrap">
  <table>
    <thead>
      <tr><th>Name</th><th>Email</th><th>WhatsApp</th><th>SLA</th><th>Products</th><th>Orders</th><th></th></tr>
    </thead>
    <tbody>
      <% if (suppliers.length === 0) { %>
      <tr><td colspan="7" style="text-align:center;padding:2rem;" class="text-muted">No suppliers yet.</td></tr>
      <% } %>
      <% suppliers.forEach(s => { %>
      <tr>
        <td><a href="/admin/suppliers/<%= s.id %>"><strong><%= s.name %></strong></a></td>
        <td class="text-sm"><%= s.contact_email||'—' %></td>
        <td class="text-sm"><%= s.contact_whatsapp||'—' %></td>
        <td class="text-xs"><%= s.shipping_sla||'—' %></td>
        <td><%= s.product_count %></td>
        <td><%= s.order_count %></td>
        <td><a href="/admin/suppliers/<%= s.id %>" class="btn btn--ghost btn--sm">Edit</a></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('_footer') %>
