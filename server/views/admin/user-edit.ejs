<%- include('_header', { navActive: 'users' }) %>

<% if (locals.flash) { %>
<div class="alert alert--<%= flash.type %>" data-autodismiss><%= flash.message %></div>
<% } %>
<% if (errors && errors.length) { %>
<div class="alert alert--error"><% errors.forEach(e => { %><div><%= e %></div><% }) %></div>
<% } %>

<a href="/admin/users" class="btn btn--ghost btn--sm" style="margin-bottom:1.5rem">← Users</a>

<div class="card" style="max-width:540px;">
  <div class="card__header"><h2 class="card__title"><%= editUser ? 'Edit User' : 'New User' %></h2></div>
  <form action="/admin/users<%= editUser?.id ? '/'+editUser.id : '' %>" method="post">
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <div class="field">
        <label class="field__label">Full Name <sup>*</sup></label>
        <input class="field__input" type="text" name="name" value="<%= editUser?.name||'' %>" required>
      </div>
      <div class="field">
        <label class="field__label">Email <sup>*</sup></label>
        <input class="field__input" type="email" name="email" value="<%= editUser?.email||'' %>" required>
      </div>
      <div class="field">
        <label class="field__label">Role</label>
        <select class="field__select" name="role">
          <option value="editor" <%=(editUser?.role||'editor')==='editor'?'selected':''%>>Editor</option>
          <option value="admin"  <%=editUser?.role==='admin'?'selected':''%>>Admin</option>
        </select>
      </div>
      <div class="field">
        <label class="field__label"><%= editUser ? 'New Password (leave blank to keep current)' : 'Password *' %></label>
        <input class="field__input" type="password" name="password" autocomplete="new-password" minlength="8" <%= editUser?'':'required' %>>
        <span class="field__hint">Minimum 8 characters.</span>
      </div>
      <% if (editUser) { %>
      <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.875rem;">
        <input type="checkbox" name="unlock" value="1"> Unlock account & reset failed attempts
      </label>
      <% } %>
      <div style="display:flex;gap:.5rem;">
        <button type="submit" class="btn btn--primary">Save User</button>
        <a href="/admin/users" class="btn btn--ghost">Cancel</a>
      </div>
    </div>
  </form>
</div>

<%- include('_footer') %>
